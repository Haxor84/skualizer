# ===============================================
# SKUALIZER - Environment Variables Example
# ===============================================
# 
# ISTRUZIONI:
# 1. Rinomina questo file come ".env"
# 2. Compila con le TUE credenziali
# 3. NON caricare MAI il file .env su GitHub
#
# Questo file è per FUTURA migrazione a sistema .env
# Attualmente il progetto usa ancora config.php
# ===============================================

# === DATABASE ===
DB_HOST=localhost
DB_NAME=nome_database
DB_USER=username_database
DB_PASS=password_database
DB_CHARSET=utf8mb4

# === APPLICATION ===
BASE_URL=https://www.tuosito.com/modules/margynomic
SITE_NAME=Margynomic
ADMIN_EMAIL=admin@tuosito.com
DEBUG_MODE=false

# === SMTP EMAIL ===
SMTP_HOST=mailserver.tuoprovider.com
SMTP_PORT=587
SMTP_SECURE=TLS
SMTP_USER=email@tuosito.com
SMTP_PASS=password_smtp
SMTP_FROM_EMAIL=email@tuosito.com
SMTP_FROM_NAME=Skualizer AI System

# === AI API KEYS ===
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_KEY_HERE
GEMINI_API_KEY=YOUR_KEY_HERE

# === AMAZON SP-API ===
AMAZON_CLIENT_ID=amzn1.application-oa2-client.YOUR_ID
AMAZON_CLIENT_SECRET=amzn1.oa2-cs.v1.YOUR_SECRET
AMAZON_REFRESH_TOKEN=Atzr|YOUR_TOKEN
AWS_ACCESS_KEY_ID=AKIA_YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
AWS_REGION=eu-west-1
AMAZON_MARKETPLACE_ID=APJ6JRA9NG5V4

# === SECURITY ===
SESSION_LIFETIME=3600
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5

# === LOGGING ===
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
