// === CONFIGURAZIONE LOGGING AVANZATA ===
define('LOG_LEVEL_NONE', 0);      // Nessun log
define('LOG_LEVEL_ERROR', 1);     // Solo errori critici
define('LOG_LEVEL_WARNING', 2);   // Errori + warning
define('LOG_LEVEL_INFO', 3);      // Errori + warning + info
define('LOG_LEVEL_DEBUG', 4);     // Tutti i log (molto verboso)

// Imposta livello log globale (cambia questo per controllare verbosità)
define('CURRENT_LOG_LEVEL', LOG_LEVEL_WARNING); // Cambia a LOG_LEVEL_ERROR per produzione

/**
 * Funzione di logging condizionale
 */
function conditionalLog($message, $level = LOG_LEVEL_INFO, $prefix = 'SYSTEM') {
    if (CURRENT_LOG_LEVEL >= $level) {
        $levelNames = [
            LOG_LEVEL_ERROR => 'ERROR',
            LOG_LEVEL_WARNING => 'WARNING', 
            LOG_LEVEL_INFO => 'INFO',
            LOG_LEVEL_DEBUG => 'DEBUG'
        ];
        $levelName = $levelNames[$level] ?? 'UNKNOWN';
        error_log("[{$prefix}] [{$levelName}] {$message}");
    }
}

// === CONFIGURAZIONE LOGGING CENTRALIZZATA ===
require_once __DIR__ . '/CentralLogger.php';

/**
 * Trova dinamicamente il percorso logs da qualsiasi posizione
 */
function getLogBasePath() {
    $currentDir = __DIR__;
    
    // Risali fino a trovare la cartella "modules"
    while (basename($currentDir) !== 'modules' && $currentDir !== dirname($currentDir)) {
        $currentDir = dirname($currentDir);
    }
    
    // Se siamo in modules/, aggiungi logs/
    if (basename($currentDir) === 'modules') {
        return $currentDir . '/logs/';
    }
    
    // Fallback: percorso relativo da config
    return __DIR__ . '/../../logs/';
}

define('LOG_BASE_DIR', getLogBasePath());
