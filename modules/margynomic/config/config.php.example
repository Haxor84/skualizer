/**
 * Connessione al database
 */
function getDbConnection() {
    static $pdo = null;
    
    if ($pdo === null) {
        try {
            $dsn = "mysql:host=" . DB_HOST . ";dbname=" . DB_NAME . ";charset=" . DB_CHARSET;
            $options = [
                PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
                PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
                PDO::ATTR_EMULATE_PREPARES => false,
            ];
            
            $pdo = new PDO($dsn, DB_USER, DB_PASS, $options);
        } catch (PDOException $e) {
            error_log("Database connection failed: " . $e->getMessage());
            die("Errore di connessione al database. Riprova più tardi.");
        }
    }
    
    return $pdo;
}

/**
 * Inizializza sessione sicura
 */
function initSecureSession() {
    if (session_status() === PHP_SESSION_NONE) {
        // Configurazione sicura della sessione
        ini_set('session.cookie_httponly', 1);
        ini_set('session.cookie_secure', isset($_SERVER['HTTPS']));
        ini_set('session.use_strict_mode', 1);
        ini_set('session.cookie_samesite', 'Strict');
        
        session_start();
        
        // Rigenera ID sessione per sicurezza
        if (!isset($_SESSION['initiated'])) {
            session_regenerate_id(true);
            $_SESSION['initiated'] = true;
        }
    }
}

/**
 * Funzioni di autoload per le classi
 */
spl_autoload_register(function ($className) {
    $directories = [
        __DIR__ . '/../login/',
        __DIR__ . '/../models/',
    ];
    
    foreach ($directories as $directory) {
        $file = $directory . $className . '.php';
        if (file_exists($file)) {
            require_once $file;
            return;
        }
    }
});

// Inizializza sessione solo se headers non sono stati inviati
if (!headers_sent()) {
    initSecureSession();
}

// === ENTERPRISE MAPPING SYSTEM ===
define('ENTERPRISE_MAPPING_ENABLED', true);
define('ENTERPRISE_MAPPING_PATH', '/modules/mapping/');

/**
 * Ottieni istanza Enterprise Mapping Engine
 */
function getEnterpriseMappingEngine() {
    static $engine = null;
    
    if ($engine === null && ENTERPRISE_MAPPING_ENABLED) {
        try {
            $mappingPath = dirname(__DIR__, 2) . '/mapping/';
            $configPath = $mappingPath . 'config/mapping_config.php';
            
            // DEBUG: Log del percorso
            error_log("ENTERPRISE DEBUG: Tentativo caricamento da: " . $mappingPath);
            
            if (file_exists($mappingPath . 'MappingService.php') && file_exists($configPath)) {
                require_once $mappingPath . 'MappingRepository.php';
                require_once $mappingPath . 'MappingService.php';
                require_once $configPath;
                
                $config = getMappingConfig();
                $repository = new MappingRepository(getDbConnection(), $config);
                $engine = new MappingService($repository, $config);
                
                error_log("ENTERPRISE DEBUG: Engine creato con successo");
            } else {
                error_log("ENTERPRISE DEBUG: File mancanti in " . $mappingPath);
            }
        } catch (Exception $e) {
            error_log("Errore caricamento Enterprise Mapping Engine: " . $e->getMessage());
        }
    }
    
    return $engine;
}

/**
 * Verifica se enterprise mapping è disponibile
 */
function isEnterpriseMappingAvailable() {
    return ENTERPRISE_MAPPING_ENABLED && getEnterpriseMappingEngine() !== null;
}

/**
 * Inizializza directory mapping enterprise
 */
function initializeEnterpriseMappingDirectories() {
    $baseDir = __DIR__ . '/../../mapping';
    $directories = [
        $baseDir,
        $baseDir . '/config',
        $baseDir . '/interfaces', 
        $baseDir . '/sources',
        $baseDir . '/strategies',
        $baseDir . '/migration',
        $baseDir . '/utils'
    ];
    
    foreach ($directories as $dir) {
        if (!is_dir($dir)) {
            mkdir($dir, 0755, true);
        }
    }
    
    // Crea file log se non esiste
    $logDir = LOG_BASE_DIR; // Usa la costante globale
    $logFile = $logDir . 'enterprise_mapping.log';
    
    if (!is_dir($logDir)) {
        mkdir($logDir, 0755, true);
    }
    
    if (!file_exists($logFile)) {
        touch($logFile);
        chmod($logFile, 0644);
    }
}

// Inizializza directory al caricamento
if (ENTERPRISE_MAPPING_ENABLED) {
    initializeEnterpriseMappingDirectories();
}

?>
