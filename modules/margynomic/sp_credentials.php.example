    'refresh_token' => 'Atzr|YOUR_REFRESH_TOKEN_HERE',                        // ← Refresh Token (dopo autorizzazione)
    
    // AWS IAM Credentials per SP-API
    'aws_access_key_id'     => 'AKIA_YOUR_ACCESS_KEY_HERE',    // ← AWS Access Key ID
    'aws_secret_access_key' => 'YOUR_AWS_SECRET_KEY_HERE',     // ← AWS Secret Access Key
    
    // AWS Region e Marketplace
    'region' => 'eu-west-1',                  // Regione AWS (Europa: eu-west-1)
