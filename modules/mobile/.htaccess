# Skualizer Mobile - Apache Configuration

# === CACHE CONTROL ===
<IfModule mod_expires.c>
    ExpiresActive On
    
    # CSS e JavaScript - 1 mese
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Immagini e SVG - 1 mese
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    
    # HTML e PHP - No cache
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/x-httpd-php "access plus 0 seconds"
</IfModule>

# === GZIP COMPRESSION ===
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# === SECURITY HEADERS ===
<IfModule mod_headers.c>
    # X-Content-Type-Options
    Header set X-Content-Type-Options "nosniff"
    
    # X-Frame-Options (protegge da clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"
    
    # X-XSS-Protection (legacy, ma utile per browser vecchi)
    Header set X-XSS-Protection "1; mode=block"
    
    # Cache-Control per assets statici
    <FilesMatch "\.(css|js|svg)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    
    # No cache per PHP
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# === CONTENT SECURITY POLICY (Opzionale - Decommentare se necessario) ===
# <IfModule mod_headers.c>
#     Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self';"
# </IfModule>

# === REWRITE RULES (Opzionale - Per URL puliti) ===
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteBase /modules/mobile/
#     
#     # Redirect www a non-www (se necessario)
#     # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
#     # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
#     
#     # Force HTTPS (se necessario)
#     # RewriteCond %{HTTPS} off
#     # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# === DENY ACCESS TO SENSITIVE FILES ===
<FilesMatch "(^\.htaccess|\.git|\.env|composer\.json|composer\.lock|package\.json|README\.md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# === DEFAULT CHARSET ===
AddDefaultCharset UTF-8

# === MIME TYPES ===
<IfModule mod_mime.c>
    AddType text/css .css
    AddType application/javascript .js
    AddType image/svg+xml .svg
    AddType application/json .json
</IfModule>

